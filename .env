# ──────────────────────────────────────────────
#  AVIVO AVI — Environment Configuration
#  Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────

# Required: Telegram bot token from @BotFather
TELEGRAM_TOKEN=bot-token-here

# Ollama server URL]
# • Local (host machine): http://localhost:11434
# • Docker to host (macOS/Windows): http://host.docker.internal:11434
# • Remote server: http://<server-ip>:11434
OLLAMA_HOST=http://localhost:11434

# LLM model for RAG generation and summarisation
# Must be pulled on the Ollama host: ollama pull mistral:7b
LLM_MODEL=mistral:7b

# Vision model for image captioning
# Must be pulled on the Ollama host: ollama pull llava:7b
VISION_MODEL=llava:7b

# Embedding model (HuggingFace model name)
# Options: all-MiniLM-L6-v2 (fast, 80MB) | Snowflake/snowflake-arctic-embed-s (higher recall)
EMBEDDING_MODEL=Snowflake/snowflake-arctic-embed-s

# RAG retrieval settings
TOP_K=5                   # Number of document chunks retrieved per query
MAX_CONTEXT_CHARS=3000    # Max characters of context fed to the LLM

# Conversation history (per user, in-memory)
MAX_HISTORY=3

# Document chunking settings (used during rag/ingest.py)
CHUNK_SIZE=250            # Words per chunk
CHUNK_OVERLAP=50          # Overlapping words between consecutive chunks
